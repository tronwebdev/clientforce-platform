# Database (see packages/db/.env.example)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/clientforce"
APP_DATABASE_URL="postgresql://clientforce_app@localhost:5432/clientforce"

# Auth — production: OIDC/JWKS. Production IdP = Clerk (env config only, no SDK).
# AUTH_JWKS_URL="https://<your-clerk-frontend-api>/.well-known/jwks.json"
# AUTH_ISSUER="https://<your-clerk-frontend-api>"
# AUTH_AUDIENCE="clientforce-api"   # optional; set if you configure a JWT audience
#
# Clerk org claims drive tenancy: the token's org_id resolves the active
# Workspace by Workspace.clerkOrgId (set at provisioning). org_role seeds a
# membership's role ONLY at first login (just-in-time); afterwards the DB role
# is authoritative. Override the seed mapping with AUTH_ROLE_MAP (JSON):
# AUTH_ROLE_MAP='{"org:owner":"OWNER","org:admin":"ADMIN","org:member":"AGENT","org:viewer":"VIEWER"}'

# Auth — dev/test only: HS256 shared secret (mints + verifies local tokens)
AUTH_DEV_SECRET="dev-secret-change-me"

# API port (optional)
# PORT=3001
