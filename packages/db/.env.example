# Privileged owner connection — migrations, seed, admin/agency reads. Bypasses RLS.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/clientforce"

# Runtime connection as the non-superuser `clientforce_app` role — subject to RLS.
# Used by the tenant-scoped client and the RLS isolation test.
APP_DATABASE_URL="postgresql://clientforce_app@localhost:5432/clientforce"
