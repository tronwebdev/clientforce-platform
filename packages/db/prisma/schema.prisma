// Clientforce Platform — Prisma schema (DATA_MODEL.md §1–§7).
//
// Conventions (DATA_MODEL.md): ids are cuid(); money & credits are integer minor
// units; createdAt/updatedAt on every model; Postgres enums. Every tenant-scoped
// table carries `workspaceId` and is protected by Postgres RLS (see the
// migration `*_rls_policies`). Agency-level rows are keyed by `agencyId` instead
// and are not workspace-scoped.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

// ─────────────────────────────────────────────────────────────────────────────
// §1 Tenancy — the 3-level white-label hierarchy (Agency → Workspace → User)
// ─────────────────────────────────────────────────────────────────────────────

model Agency {
  id               String       @id @default(cuid())
  name             String
  slug             String       @unique
  branding         Json
  planTier         AgencyPlan   @default(GROWTH)
  status           TenantStatus @default(ACTIVE)
  stripeCustomerId String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  workspaces       Workspace[]
  plans            Plan[]
  creditPrices     CreditPrice[]
}

model Workspace {
  id            String       @id @default(cuid())
  agencyId      String
  agency        Agency       @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  name          String
  slug          String
  // Immutable Clerk Organization id — the auth layer resolves the active
  // workspace by this (not by slug). Set at provisioning time (T7).
  clerkOrgId    String?      @unique
  status        TenantStatus @default(ACTIVE)
  branding      Json?
  planId        String?
  creditBalance Int          @default(0)
  settings      Json
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  memberships   Membership[]

  @@unique([agencyId, slug])
  @@index([agencyId])
}

model User {
  id             String       @id @default(cuid())
  email          String       @unique
  name           String?
  authProviderId String?      @unique
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  memberships    Membership[]
}

model Membership {
  id          String    @id @default(cuid())
  userId      String
  workspaceId String
  role        Role      @default(AGENT)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([workspaceId])
}

enum AgencyPlan {
  STARTER
  GROWTH
  SCALE
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum Role {
  OWNER
  ADMIN
  AGENT
  VIEWER
}

// ─────────────────────────────────────────────────────────────────────────────
// §2 Knowledge & business context (pgvector)
// ─────────────────────────────────────────────────────────────────────────────

model KnowledgeSource {
  id          String           @id @default(cuid())
  workspaceId String
  agentId     String?
  kind        SourceKind
  uri         String?
  label       String
  status      IngestStatus     @default(PENDING)
  meta        Json
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  chunks      KnowledgeChunk[]

  @@index([workspaceId])
}

model KnowledgeChunk {
  id          String          @id @default(cuid())
  workspaceId String
  sourceId    String
  content     String
  // P1.2: 1536-dim (text-embedding-3-large, dimensions=1536 via @clientforce/ai)
  // with an hnsw cosine index — resolves T1's TODO(phase-1).
  embedding   Unsupported("vector(1536)")
  tokens      Int
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  source      KnowledgeSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([sourceId])
}

// P1.3 (DEC-024/025): two-layer context — one row per agent PLUS one
// workspace-layer row (agentId null, Brand kit). Uniqueness is enforced by
// partial unique indexes in the migration (Prisma can't express them):
// UNIQUE(agentId) WHERE agentId IS NOT NULL · UNIQUE(workspaceId) WHERE agentId IS NULL.
// `fields` is the registry-keyed map { value, citations: chunkId[], source }.
model BusinessContext {
  id          String        @id @default(cuid())
  workspaceId String
  agentId     String?
  goal        String?
  status      ContextStatus @default(READY)
  fields       Json          @default("{}")
  // Custom-goal distiller-proposed asks: [{ key, ask, dismissed? }] (DEC-024).
  proposedAsks Json          @default("[]")
  rawSummary   String        @default("")
  distilledAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  agent       Agent?        @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([agentId])
}

enum ContextStatus {
  DISTILLING
  READY
}

enum SourceKind {
  WEBSITE
  DOCUMENT
  CONNECTOR
  TEXT
}

enum IngestStatus {
  PENDING
  INGESTING
  READY
  FAILED
}

// ─────────────────────────────────────────────────────────────────────────────
// §3 Agents, campaigns & the Campaign Graph
// ─────────────────────────────────────────────────────────────────────────────

model Agent {
  id              String           @id @default(cuid())
  workspaceId     String
  name            String
  goal            String
  category        String?
  instructions    String?
  status          AgentStatus      @default(DRAFT)
  guardrails      Json
  /// B6: wizard draft-resume working set (core `draftStateSchema`); NULL once launched.
  draftState      Json?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  campaigns        Campaign[]
  businessContexts BusinessContext[]

  @@index([workspaceId])
}

model Campaign {
  id          String          @id @default(cuid())
  workspaceId String
  agentId     String
  name        String
  graphId     String
  status      CampaignStatus  @default(ACTIVE)
  /// LH1 (DEC-087): per-day-per-campaign enrollment cap — bounds the QUEUE
  /// feeding the send caps (effective send volume stays min(warmup curve,
  /// dailyLimit) — untouched). null = the platform default constant
  /// (`ENROLLMENT_DAILY_CAP_DEFAULT`); enforced at the enrollment gate for
  /// EVERY source. Default ON; owner-flippable per campaign.
  enrollmentDailyCap   Int?
  enrollmentCapEnabled Boolean @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  agent       Agent           @relation(fields: [agentId], references: [id], onDelete: Cascade)
  graphs      CampaignGraph[]
  enrollments Enrollment[]
  rules       CampaignRule[]

  @@index([workspaceId])
  @@index([agentId])
}

model CampaignGraph {
  id          String      @id @default(cuid())
  workspaceId String
  campaignId  String
  version     Int
  graph       Json
  source      GraphSource @default(AI)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  campaign    Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, version])
  @@index([workspaceId])
}

enum AgentStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum CampaignStatus {
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum GraphSource {
  AI
  TEMPLATE
  MANUAL
}

// ─────────────────────────────────────────────────────────────────────────────
// §4 Leads, enrollment & pipeline
// ─────────────────────────────────────────────────────────────────────────────

/// C2.7: workspace-defined custom field (docs/PLAN_CUSTOM_FIELDS.md). `key` is
/// an immutable slug; archive-never-delete (values stay in Contact.custom).
model ContactFieldDef {
  id          String    @id @default(cuid())
  workspaceId String
  key         String
  label       String
  type        FieldType @default(TEXT)
  options     String[]
  origin      String
  archived    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([workspaceId, key])
  @@index([workspaceId])
}

enum FieldType {
  TEXT
  NUMBER
  DATE
  SELECT
}

model Contact {
  id          String           @id @default(cuid())
  workspaceId String
  email       String?
  phone       String?
  firstName   String?
  lastName    String?
  company     String?
  title       String?
  source      String
  enrichment  Json?
  /// C2.7: user-entered custom-field values keyed by ContactFieldDef.key —
  /// never mixed with `enrichment` (reserved for machine enrichment).
  custom      Json             @default("{}")
  tags        String[]
  optOut      Json
  /// LH1 (DEC-087): email-validation verdict — valid | risky | invalid |
  /// unverified (default; `EMAIL_VERDICTS` in @clientforce/core is the
  /// enum of record). The enrollment gate reads this. The suppression
  /// ledger stays authoritative: a verdict NEVER un-suppresses.
  emailVerdict          String    @default("unverified")
  emailVerdictCheckedAt DateTime?
  /// zerobounce | cache | syntax | mx — which pass produced the verdict.
  emailVerdictSource    String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  lists       ContactListMember[]
  enrollments Enrollment[]
  events      Event[]

  @@index([workspaceId, email])
  @@index([workspaceId, phone])
  @@index([workspaceId, emailVerdict])
}

model Enrollment {
  id            String           @id @default(cuid())
  workspaceId   String
  campaignId    String
  contactId     String
  workflowId    String           @unique
  pipelineStage String
  currentNode   String?
  status        EnrollmentStatus @default(ACTIVE)
  // P1.6: user-visible run audit — send-boundary refusals ({blocked}), intended
  // actions, branch routing. The Logs tab renders refusals as amber rows.
  meta          Json             @default("{}")
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  campaign      Campaign         @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact       Contact          @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([campaignId, contactId])
  @@index([workspaceId])
}

model PipelineStage {
  id          String   @id @default(cuid())
  workspaceId String
  campaignId  String?
  key         String
  label       String
  order       Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([workspaceId])
}

model ContactList {
  id          String              @id @default(cuid())
  workspaceId String
  name        String
  /// C2.8 (docs/PLAN_CONTACT_LISTS.md): "manual" | "csv_import" | "form" |
  /// "widget" | "automation" — future origins RESERVED for the integrations.
  origin      String
  /// Archive, never delete (same rule as ContactFieldDef).
  archived    Boolean             @default(false)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  members     ContactListMember[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
}

/// C2.8: explicit membership (lists ≠ segments — segments stay derived).
/// The plan's composite identity lives in @@unique([listId, contactId]); the
/// surrogate id is retained from the Phase-0 table (no FK churn), and
/// workspaceId stays for the house RLS pattern.
model ContactListMember {
  id          String      @id @default(cuid())
  workspaceId String
  listId      String
  contactId   String
  addedAt     DateTime    @default(now())
  /// userId | "import" | "automation"
  addedBy     String
  list        ContactList @relation(fields: [listId], references: [id], onDelete: Cascade)
  contact     Contact     @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([listId, contactId])
  @@index([workspaceId])
}

enum EnrollmentStatus {
  ACTIVE
  PAUSED
  DONE
  UNSUBSCRIBED
  BOUNCED
}

/// LH1 (DEC-087): workspace-scoped verdict cache — one row per normalized
/// address; re-imports/re-enrolls inside the TTL (~90d) never re-bill the
/// provider. `billedAt` is the COGS meter: set only when a PAID provider
/// call produced the verdict (free-filter verdicts carry billedAt = null),
/// so allowance/ceiling/usage counts are one indexed count away.
model EmailValidationVerdict {
  id          String    @id @default(cuid())
  workspaceId String
  /// Lowercased, trimmed address — the cache key.
  address     String
  /// valid | risky | invalid (an unknown-yet address simply has no row).
  verdict     String
  /// Provider sub-status (e.g. "mailbox_not_found") — report row detail.
  subStatus   String?
  /// zerobounce | syntax | mx — which pass wrote it.
  source      String
  checkedAt   DateTime  @default(now())
  expiresAt   DateTime
  billedAt    DateTime?
  costMicros  Int       @default(0)

  @@unique([workspaceId, address])
  @@index([workspaceId, billedAt])
  @@index([billedAt])
}

/// LH1 (DEC-087): one async validation run (a CSV import, a single add).
/// Validation NEVER blocks a flow — batches carry honest progress and honest
/// holds (allowance / spend ceiling / provider down), and the report reads
/// item outcomes progressively as chunks return.
model ValidationBatch {
  id          String                @id @default(cuid())
  workspaceId String
  /// Client idempotency key (the web import flow's uuid) — every chunk of
  /// one import lands on ONE batch.
  clientKey   String?
  /// csv_import | manual | single
  source      String
  /// queued | running | held | completed
  status      String                @default("queued")
  /// workspace_allowance | platform_spend_ceiling | provider_unavailable
  heldReason  String?
  listId      String?
  /// Optimistic chunk-claim lease — a second worker turn on the same batch
  /// skips instead of double-billing the provider.
  claimedUntil DateTime?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  completedAt DateTime?
  items       ValidationBatchItem[]

  @@unique([workspaceId, clientKey])
  @@index([workspaceId, status])
}

model ValidationBatchItem {
  id          String          @id @default(cuid())
  workspaceId String
  batchId     String
  contactId   String
  address     String
  /// pending | valid | risky | invalid | skipped_suppressed
  outcome     String          @default("pending")
  /// zerobounce | cache | syntax | mx | suppression
  via         String?
  detail      String?
  billed      Boolean         @default(false)
  updatedAt   DateTime        @updatedAt
  batch       ValidationBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@unique([batchId, contactId])
  @@index([workspaceId])
  @@index([batchId, outcome])
}

/// LH1 (DEC-087): the enrollment gate's hold queue — a persisted INTENT to
/// enroll that drains progressively as verdicts return and the daily cap
/// frees. A hold owns no workflow; it becomes an Enrollment only back
/// through the gate. Reasons: unverified (validation pending) · risky_held
/// (workspace policy, default hold) · cap_overflow (drains next day).
model EnrollmentHold {
  id           String   @id @default(cuid())
  workspaceId  String
  campaignId   String
  agentId      String
  contactId    String
  senderId     String?
  origin       Json?
  reason       String
  /// pending | released | refused
  status       String   @default("pending")
  /// Typed refusal code when refused (CONTACT_INVALID).
  refusalCode  String?
  /// The Enrollment created when this hold released.
  enrollmentId String?
  requestedAt  DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([campaignId, contactId])
  @@index([workspaceId, status])
  @@index([campaignId, status])
}

// ─────────────────────────────────────────────────────────────────────────────
// §5 Events — the immutable backbone
// ─────────────────────────────────────────────────────────────────────────────

model Event {
  id           String   @id @default(cuid())
  workspaceId  String
  type         String
  contactId    String?
  enrollmentId String?
  campaignId   String?
  /// P5 W1 (DEC-083): sender attribution (backfilled via payload.messageId →
  /// Message) — the health engine's per-sender window rollup is one index scan.
  senderId     String?
  payload      Json
  occurredAt   DateTime @default(now())
  createdAt    DateTime @default(now())
  contact      Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([workspaceId, type, occurredAt])
  @@index([enrollmentId])
  // F1 (DEC-068): the outcomes rollup filters campaign + type set per request.
  @@index([workspaceId, campaignId, type])
  // P5 W1 (DEC-083): the health window rollup (sender + type set + window).
  @@index([workspaceId, senderId, type, occurredAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// §6 Automations, integrations, channels
// ─────────────────────────────────────────────────────────────────────────────

model Automation {
  id          String          @id @default(cuid())
  workspaceId String
  name        String
  enabled     Boolean         @default(true)
  trigger     Json
  conditions  Json
  actions     Json
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  runs        AutomationRun[]

  @@index([workspaceId])
}

model AutomationRun {
  id           String     @id @default(cuid())
  workspaceId  String
  automationId String
  /// R1-UI (DEC-088, additive): the bus Event row id (or the sweep's synthetic
  /// fire-once key `quiet:<enrollmentId>`) for DIRECT account-rule fires —
  /// unique (automationId, eventId) = redelivery idempotency, the
  /// CampaignRuleRun pattern. NULL on nested `run_automation` rows (their
  /// idempotency lives in the outer rule's (ruleId, eventId) key) and on
  /// pre-DEC-088 history.
  eventId      String?
  status       String
  detail       Json
  ranAt        DateTime   @default(now())
  automation   Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)

  @@unique([automationId, eventId])
  @@index([workspaceId])
  @@index([automationId])
}

/// R1 (DEC-074): per-agent automation rules (ARCHITECTURE §151) — the
/// campaign-scoped SIBLING of the standalone `Automation` (§152, Phase 6),
/// sharing the typed trigger/condition/action unions in `@clientforce/core`
/// but a DISTINCT entity: rules carry row order, goal-seed provenance,
/// wizard-draft lifecycle, and the graph interlock (terminal-action skip) —
/// none of which exists for account automations.
model CampaignRule {
  id          String            @id @default(cuid())
  workspaceId String
  campaignId  String
  /// Evaluation order — ascending; first terminal action wins conflicts.
  order       Int
  trigger     Json
  condition   Json?
  actions     Json
  enabled     Boolean           @default(true)
  /// Goal-seed provenance (W2) — seeds are rows like any other.
  seededFrom  String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  campaign    Campaign          @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  runs        CampaignRuleRun[]

  @@index([workspaceId])
  @@index([campaignId])
}

/// R1 (DEC-074): rule-run history, mirroring `AutomationRun`'s shape.
/// Idempotency: unique (ruleId, eventId) — bus redelivery can't double-fire
/// (eventId is the bus Event row id, or the sweep's synthetic fire-once key
/// `quiet:<enrollmentId>` for the timer trigger).
model CampaignRuleRun {
  id           String       @id @default(cuid())
  workspaceId  String
  ruleId       String
  enrollmentId String?
  contactId    String?
  eventId      String
  status       String
  detail       Json
  /// Causation depth (rule → run automation → …); evaluator refuses > 2.
  depth        Int          @default(0)
  ranAt        DateTime     @default(now())
  rule         CampaignRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@unique([ruleId, eventId])
  @@index([workspaceId])
  @@index([ruleId])
}

model Integration {
  id          String   @id @default(cuid())
  workspaceId String
  provider    String
  status      String   @default("connected")
  credentials Json
  config      Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([workspaceId])
}

// P1.5: the three-tier sender model (issue P1.5; replaces the T1 `Sender`
// placeholder — DEC-030). Per-tenant credentials live ONLY in credentialsEnc
// (AES-256-GCM under the FIELD-ENCRYPTION-KEY master key); CF_MANAGED shared
// pool carries none. warmupState/dedicatedIp/ipPoolId/subuser are reserved so
// later tiers are additive (DEC-019).
model SenderConnection {
  id               String       @id @default(cuid())
  workspaceId      String
  type             SenderType
  fromEmail        String
  // Owner rule 1 (2026-07-04): a send through a sender without a from-name
  // FAILS at the boundary — the signature merge token must never render blank.
  fromName         String?
  replyTo          String?
  status           SenderStatus @default(ACTIVE)
  domainAuthStatus Json         @default("{}")
  dailyLimit       Int          @default(200)
  sendingWindow    Json?
  credentialsEnc   Bytes?
  warmupState      Json?
  dedicatedIp      String?
  ipPoolId         String?
  subuser          String?
  /// P5 W1 (DEC-083): deterministic health snapshot ({ v, score, state, floor,
  /// sample, rates, computedAt }) — written by the worker sweep + webhook fast
  /// path from ledger aggregates; the send boundary reads `state` only.
  healthState      Json?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([workspaceId])
}

enum SenderType {
  CF_MANAGED
  GMAIL_OAUTH
  OUTLOOK_OAUTH
  SMTP
  /// P2.1 (DEC-061): Twilio SMS — phone rides the fromEmail column (enum-only
  /// migration); messagingServiceSid rides credentialsEnc (field-encrypted).
  TWILIO_SMS
}

enum SenderStatus {
  ACTIVE
  PAUSED
  DISABLED
}

// P1.5 (handoff A6): every outbound persisted AS RENDERED at send time;
// P1.7 persists every inbound + its classified intent.
model Message {
  id                String           @id @default(cuid())
  workspaceId       String
  campaignId        String
  enrollmentId      String?
  contactId         String
  channel           String
  direction         MessageDirection
  subject           String?
  body              String
  providerMessageId String?          @unique
  inReplyToId       String?
  intent            String?
  stepNodeId        String?
  /// P5 W1 (DEC-083): sender attribution as a real column (backfilled from
  /// meta.senderId, which stays for compat) — warmup caps + health rollups.
  senderId          String?
  sentAt            DateTime
  meta              Json?

  @@index([workspaceId, contactId, sentAt])
  @@index([workspaceId, campaignId, sentAt])
  @@index([workspaceId, senderId, channel, sentAt])
}

enum MessageDirection {
  OUTBOUND
  INBOUND
}

// P1.5 (handoff A7): checked at the send boundary together with
// Contact.optOut; unsubscribe/bounce/spam events write rows here.
model Suppression {
  id          String            @id @default(cuid())
  workspaceId String
  channel     String
  address     String
  reason      SuppressionReason
  source      String?
  createdAt   DateTime          @default(now())

  @@unique([workspaceId, channel, address])
  @@index([workspaceId])
}

enum SuppressionReason {
  UNSUBSCRIBED
  BOUNCED
  SPAM_COMPLAINT
  MANUAL
}

model WebhookEndpoint {
  id          String            @id @default(cuid())
  workspaceId String
  url         String
  secret      String
  events      String[]
  enabled     Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  deliveries  WebhookDelivery[]

  @@index([workspaceId])
}

model WebhookDelivery {
  id            String          @id @default(cuid())
  workspaceId   String
  endpointId    String
  eventType     String
  payload       Json
  status        String          @default("pending")
  responseCode  Int?
  attempts      Int             @default(0)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  endpoint      WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([endpointId])
}

// ─────────────────────────────────────────────────────────────────────────────
// §7 Billing, credits & forms/proposals/widget
// ─────────────────────────────────────────────────────────────────────────────

model Plan {
  id           String   @id @default(cuid())
  agencyId     String?
  name         String
  priceMonthly Int
  features     Json
  limits       Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  agency       Agency?  @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@index([agencyId])
}

model CreditPrice {
  id            String   @id @default(cuid())
  agencyId      String?
  action        String
  credits       Int
  effectiveFrom DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  agency        Agency?  @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@index([agencyId, action])
}

model CreditLedger {
  id           String   @id @default(cuid())
  workspaceId  String
  delta        Int
  reason       String
  channel      String?
  refId        String?
  balanceAfter Int
  createdAt    DateTime @default(now())

  @@index([workspaceId])
}

model Form {
  id          String           @id @default(cuid())
  workspaceId String
  title       String
  fields      Json
  design      Json
  routing     Json
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  submissions FormSubmission[]

  @@index([workspaceId])
}

model FormSubmission {
  id          String   @id @default(cuid())
  workspaceId String
  formId      String
  contactId   String?
  answers     Json
  submittedAt DateTime @default(now())
  form        Form     @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([formId])
}

model Proposal {
  id          String         @id @default(cuid())
  workspaceId String
  title       String
  blocks      Json
  variables   Json
  status      String         @default("draft")
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  sends       ProposalSend[]

  @@index([workspaceId])
}

model ProposalSend {
  id            String    @id @default(cuid())
  workspaceId   String
  proposalId    String
  contactId     String
  channel       String
  trackedLinkId String    @unique
  viewedAt      DateTime?
  acceptedAt    DateTime?
  paidAt        DateTime?
  amount        Int?
  createdAt     DateTime  @default(now())
  proposal      Proposal  @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([proposalId])
}

model Widget {
  id          String   @id @default(cuid())
  workspaceId String
  agentId     String
  design      Json
  fields      Json
  behaviour   Json
  routing     Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([workspaceId])
}

// Client-billing / agency payouts (agency charging its own clients) are a
// DEFERRED v2 concern — not in the initial build (DATA_MODEL.md §7).
// model AgencyPayout { ... }

// ─────────────────────────────────────────────────────────────────────────────
// §8 Analytics — rollups (events are the source of truth; see §8)
// ─────────────────────────────────────────────────────────────────────────────

model MetricDaily {
  id          String   @id @default(cuid())
  workspaceId String
  date        DateTime @db.Date
  agentId     String?
  channel     String?
  metric      String
  value       Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([workspaceId, date, agentId, channel, metric])
  @@index([workspaceId, date])
}

// ─────────────────────────────────────────────────────────────────────────────
// §9 Platform backoffice — the internal operator surface (B1 W1, DEC-079)
//
// These tables are DELIBERATELY NOT tenant-scoped: no `workspaceId`, no RLS
// policy, no tenant relation. Cross-tenant read is the backoffice's purpose.
// They are reached only by the platform-staff auth rail and the RLS-exempt
// `clientforce_backoffice` role; the migration REVOKEs them from the RLS-subject
// `clientforce_app` role so no tenant/feature path can touch them at the DB layer.
// ─────────────────────────────────────────────────────────────────────────────

// Allow-listed platform operators (owner-managed), distinct from tenant `User`s.
// A tenant credential is never in this table, so it can never open the backoffice.
model PlatformStaff {
  id        String               @id @default(cuid())
  email     String               @unique
  name      String?
  role      PlatformStaffRole    @default(OPERATOR)
  status    PlatformStaffStatus  @default(ACTIVE)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  auditLog  BackofficeAuditLog[]
}

enum PlatformStaffRole {
  OPERATOR
  ADMIN
}

enum PlatformStaffStatus {
  ACTIVE
  DISABLED
}

// Append-only audit trail: every backoffice mutation writes one row
// (operator, action, target, reason). Never updated, never deleted.
model BackofficeAuditLog {
  id            String        @id @default(cuid())
  operatorId    String
  operator      PlatformStaff @relation(fields: [operatorId], references: [id])
  // Denormalized so the audit row survives even if the staff row is later renamed.
  operatorEmail String
  action        String // e.g. "agency.suspend", "workspace.credit.adjust"
  targetType    String // "agency" | "workspace"
  targetId      String
  reason        String?
  metadata      Json? // typed context: { before, after, delta, balanceAfter, … }
  createdAt     DateTime      @default(now())

  @@index([targetType, targetId])
  @@index([operatorId])
  @@index([createdAt])
}

// Provider invoices (B1 W2, DEC-080) — the reconciliation fixture store. Platform-
// global, backoffice-only (REVOKEd from clientforce_app). We reconcile our metered
// usage (from the event ledger) against these per provider per month; this is the
// FR-BILL-04 enforcement prerequisite, not the enforcement itself.
model ProviderInvoice {
  id          String   @id @default(cuid())
  provider    String // "sendgrid" | "twilio" | "anthropic" | …
  periodStart DateTime
  periodEnd   DateTime
  metric      String // "email_sends" | "sms_segments" | "voice_minutes" | …
  quantity    Int // provider-reported quantity
  amount      Int // provider-reported amount, integer minor units (cents)
  currency    String   @default("USD")
  source      String   @default("manual") // "manual" | "csv" | "api" (provenance)
  createdAt   DateTime @default(now())

  @@index([provider, periodStart])
}

// Product telemetry (B1 W3, DEC-081) — the local, PII-free adoption store.
// Platform-global, backoffice-only (REVOKEd from clientforce_app). Powers the
// activation funnel / DAU-WAU / feature-adoption / cohort-retention dashboards
// and the sample floor; dual-written with the PostHog forward. PRIVACY RAIL:
// `props` carries ids + enums/counts ONLY — never bodies, contact PII, or
// knowledge content (enforced by the @clientforce/telemetry catalog + pinned test).
model TelemetryEvent {
  id          String   @id @default(cuid())
  name        String // versioned type, e.g. "product.agent_launched.v1"
  actorType   String // "operator" | "user" | "system"
  actorId     String?
  workspaceId String?
  agencyId    String?
  entityId    String?
  props       Json
  occurredAt  DateTime
  createdAt   DateTime @default(now())

  @@index([name, occurredAt])
  @@index([workspaceId, occurredAt])
}

// Per-agency / per-channel kill switch (B1 W4, DEC-082). Presence + active = the
// channel is killed for that agency; the send boundary refuses `CHANNEL_KILLED`
// (extends the SendBlockReason enum — the W1 TENANT_SUSPENDED pattern, no fork).
// Backoffice-WRITTEN, app-READABLE: unlike the fully-revoked W1-W3 tables, the
// RLS-subject `clientforce_app` role keeps SELECT (the send boundary reads it to
// enforce the switch) but loses INSERT/UPDATE/DELETE. Typed, reversible, audited.
model KillSwitch {
  id        String   @id @default(cuid())
  agencyId  String
  channel   String // "email" | "sms" | "whatsapp" | "voice"
  active    Boolean  @default(true)
  reason    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([agencyId, channel])
  @@index([agencyId])
}

// Per-tenant feature flags (B1 W4, DEC-082). Workspace-scoped toggles set by the
// operator (audited). Backoffice-WRITTEN, app-READABLE: `clientforce_app` keeps
// SELECT (feature gates read it) but loses INSERT/UPDATE/DELETE — only the
// backoffice mutates flags.
model FeatureFlag {
  id          String   @id @default(cuid())
  workspaceId String
  key         String
  enabled     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([workspaceId, key])
  @@index([workspaceId])
}
